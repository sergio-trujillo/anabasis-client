{
  "name": "anabasis-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite --port 5174 --strictPort\" \"cd ../anabasis-server && npx tsx watch src/index.ts\"",
    "dev:client": "vite --port 5174 --strictPort",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --port 5174"
  },
